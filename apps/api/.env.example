# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/contracthero"

# Auth
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_DOMAIN=localhost

# CORS — comma-separated allow-list of exact browser origins.
# Wildcards are NOT supported because the API issues credentialed cookies
# (browsers reject `Access-Control-Allow-Origin: *` with credentials).
# In production an empty value is fail-closed (no cross-origin requests).
CORS_ORIGINS=http://localhost:3000

# Email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
